NODE_ENV="production"
DATABASE_URL="postgresql://clinicnova:REPLACE_WITH_STRONG_PASSWORD@db.example.com:5432/clinicnova?schema=public&sslmode=require"
AUTH_SECRET="REPLACE_WITH_AT_LEAST_48_RANDOM_CHARACTERS"
AUTH_COOKIE_SECURE="true"
NEXT_PUBLIC_APP_URL="https://app.example.com"
DEMO_MODE="false"
ALLOW_PRODUCTION_DEMO="false"
CRON_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
N8N_WEBHOOK_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
N8N_OUTBOUND_WEBHOOK_URL="https://automation.example.com/webhook/clinicnova-outbound"
N8N_OUTBOUND_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
REQUIRE_LIVE_INTEGRATIONS="true"
FILE_STORAGE_ROOT="/var/lib/clinicnova/patient-files"
FILE_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"
FILE_AV_REQUIRED="true"
FILE_AV_COMMAND="clamscan"
PITR_ENABLED="true"
BACKUP_REMOTE="rclone-remote:clinicnova-production"
RESTORE_TEST_SCHEDULED="true"
